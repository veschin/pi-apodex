{
  "name": "pi-apodex",
  "version": "0.1.0",
  "description": "Verification-centric deep-reasoning extension for Pi: GVR loops, external verifier, causal candidate selection, evidence-disciplined answers",
  "type": "module",
  "private": true,
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run-eval.ts",
    "eval:smoke": "tsx eval/run-eval.ts --smoke"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.1",
    "@earendil-works/pi-coding-agent": "0.79.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
